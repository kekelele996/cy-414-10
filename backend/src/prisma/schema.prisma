generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  coach
  admin
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
}

enum CourseStatus {
  draft
  published
  archived
}

model User {
  id                 Int              @id @default(autoincrement())
  phone              String           @unique @db.VarChar(32)
  passwordHash       String           @map("password_hash") @db.VarChar(255)
  nickname           String           @db.VarChar(80)
  avatar             String?          @db.VarChar(255)
  role               UserRole         @default(student)
  gender             String?          @db.VarChar(20)
  height             Decimal?         @db.Decimal(5, 2)
  weight             Decimal?         @db.Decimal(5, 2)
  createdAt          DateTime         @default(now()) @map("created_at")
  courses            Course[]         @relation("CoachCourses")
  bookings           Booking[]
  bodyMetrics        BodyMetric[]
  coachedPlans       TrainingPlan[]   @relation("CoachTrainingPlans")
  userPlans          TrainingPlan[]   @relation("UserTrainingPlans")

  @@map("users")
}

model Course {
  id          Int          @id @default(autoincrement())
  coachId     Int          @map("coach_id")
  title       String       @db.VarChar(120)
  description String?      @db.Text
  duration    Int
  price       Decimal      @db.Decimal(10, 2)
  maxCapacity Int          @default(1) @map("max_capacity")
  schedule    Json
  status      CourseStatus @default(published)
  createdAt   DateTime     @default(now()) @map("created_at")
  coach       User         @relation("CoachCourses", fields: [coachId], references: [id])
  bookings    Booking[]

  @@index([coachId])
  @@map("courses")
}

model Booking {
  id           Int           @id @default(autoincrement())
  userId       Int           @map("user_id")
  courseId     Int           @map("course_id")
  scheduleTime DateTime      @map("schedule_time")
  status       BookingStatus @default(pending)
  note         String?       @db.VarChar(500)
  createdAt    DateTime      @default(now()) @map("created_at")
  user         User          @relation(fields: [userId], references: [id])
  course       Course        @relation(fields: [courseId], references: [id])
  trainingPlan TrainingPlan?

  @@index([userId])
  @@index([courseId])
  @@map("bookings")
}

model BodyMetric {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  weight     Decimal  @db.Decimal(5, 2)
  bodyFat    Decimal? @map("body_fat") @db.Decimal(5, 2)
  muscle     Decimal? @db.Decimal(5, 2)
  bmi        Decimal  @db.Decimal(5, 2)
  recordDate DateTime @map("record_date") @db.Date
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("body_metrics")
}

model TrainingPlan {
  id          Int                 @id @default(autoincrement())
  bookingId   Int                 @unique @map("booking_id")
  coachId     Int                 @map("coach_id")
  userId      Int                 @map("user_id")
  stageName   String?             @map("stage_name") @db.VarChar(120)
  overallNote String?             @map("overall_note") @db.Text
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  booking     Booking             @relation(fields: [bookingId], references: [id])
  coach       User                @relation("CoachTrainingPlans", fields: [coachId], references: [id])
  user        User                @relation("UserTrainingPlans", fields: [userId], references: [id])
  items       TrainingPlanItem[]

  @@index([coachId])
  @@index([userId])
  @@map("training_plans")
}

model TrainingPlanItem {
  id           Int          @id @default(autoincrement())
  planId       Int          @map("plan_id")
  exerciseName String       @map("exercise_name") @db.VarChar(120)
  sets         String?      @db.VarChar(60)
  reps         String?      @db.VarChar(60)
  note         String?      @db.VarChar(500)
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")
  plan         TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("training_plan_items")
}

